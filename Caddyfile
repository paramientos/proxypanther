{
    # Global Options
    email admin@proxypanther.com
}

# Global IP Blacklist
(blacklist) {
    @banned_ips remote_ip 1.2.3.4 5.6.7.8
    respond @banned_ips "Access Denied by ProxyPanther Global Blacklist" 403
}

http://testme.com {
    log {
        output file /Users/aras/projects/deploypanther/storage/logs/caddy-3.log
        format json
    }

    import blacklist
    # Protect Sensitive Files
    @sensitive_paths {
        path /.env* /.git* /.svn* /wp-config.php /config.php /composer.json /composer.lock
    }
    respond @sensitive_paths "Access to sensitive system files is forbidden." 403

    # Basic WAF Protection
    @attacks {
        expression {query}.contains('union') || {query}.contains('select') || {query}.contains('<script')
        header_regexp User-Agent (?i)(sqlmap|nikto|nmap)
    }
    respond @attacks "Access Denied by ProxyPanther WAF" 403

    reverse_proxy http://localhost:8001 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
    }
    # Rate Limit: 5 rps
    handle_errors {
        rewrite * /{err.status_code}.html
        respond "ProxyPanther Secure Gateway: Error {err.status_code}" {err.status_code}
    }
}

