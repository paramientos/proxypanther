app.com {
    header X-ProxyPanther-Gateway "Secure-Alpha"
    log {
        output file /Users/aras/projects/deploypanther/storage/logs/caddy-2.log
        format json
    }

    import blacklist
    @sensitive_paths {
        path /.env* /.git* /.svn* /wp-config.php /config.php /composer.json /composer.lock
    }
    respond @sensitive_paths "Access to sensitive system files is forbidden." 403

    encode brotli gzip
    @bad_bots {
        header_regexp User-Agent "(?i)(sqlmap|nikto|nmap|zgrab|masscan|burp|metasploit|gobuster|dirbuster|python-requests|curl|wget)"
    }
    error @bad_bots "Access Denied" 403
    @attacks {
        expression {query}.contains('union') && {query}.contains('select')
        expression {query}.contains('information_schema')
        expression {query}.contains('sleep(')
        expression {query}.contains('benchmark(')
        expression {query}.contains('<script')
        expression {query}.contains('javascript:')
        expression {query}.contains('onerror=')
        expression {query}.contains('../')
        expression {query}.contains('/etc/passwd')
        header_regexp User-Agent (?i)(sqlmap|nikto|nmap|zgrab|masscan|burp|metasploit|gobuster|dirbuster)
    }
    error @attacks "Access Denied by ProxyPanther Advanced WAF" 403

    import common_security_headers
    reverse_proxy http://localhost:8002
    handle_errors {
        respond "ProxyPanther Secure Gateway: Error {err.status_code}" {err.status_code}
    }
}

